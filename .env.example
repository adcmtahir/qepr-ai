# QE Test Plan Reviewer — environment config
# Copy this file to .env and fill in your values.
# Values set here are used as fallbacks; you can also enter them in the browser UI Settings.

# Your Confluence Personal Access Token
# Generate at: Confluence → Profile picture → Personal Access Tokens
CONFLUENCE_TOKEN=

# Your Anthropic API key (optional — can be entered in the browser UI instead)
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=
